{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "Single source of truth for repo-name -> canonical-slug mappings. Read by bin/generate.py and bin/backfill-host-ports.py. Never remove an entry once a service is live: the catalog URL depends on the slug being stable.",
  "overrides": {
    "go_jsbundle_secrets": "jsbundle-secrets",
    "go_jsbundle_route_extractor": "jsbundle-routes",
    "go_postmessage_listener_finder": "postmessage",
    "go_prototype_pollution_static": "proto-pollution",
    "go_jwt_pentest": "jwt-pentest",
    "go_session_fixation": "go-session-fixation",
    "go-apikey-service": "apikey-service",
    "go_oauth_mapper": "go-oauth-mapper",
    "go_domain_dnssec_validator": "domain-dnssec-validator",
    "go_domain_email_deliverability_score": "domain-email-deliverability-score",
    "go_domain_passive_dns_history": "domain-passive-dns-history",
    "go_domain_ct_log_watcher": "domain-ct-log-watcher",
    "go_domain_third_party_fetch_map": "domain-third-party-fetch-map",
    "go_domain_tech_eol_flagger": "domain-tech-eol-flagger",
    "go_domain_mobile_app_resolver": "domain-mobile-app-resolver",
    "go_domain_structured_data_rollup": "domain-structured-data-rollup",
    "go_domain_abuse_contact_rollup": "domain-abuse-contact-rollup",
    "go_domain_rbl_reputation": "domain-rbl-reputation",
    "go_domain_http3_quic_detector": "domain-http3-quic-detector",
    "go_domain_saas_host_mapper": "domain-saas-host-mapper",
    "go_domain_support_stack_detector": "domain-support-stack-detector",
    "go_domain_newsletter_platform_detector": "domain-newsletter-platform-detector",
    "go_domain_well_known_catalog": "domain-well-known-catalog",
    "go_domain_ai_bot_policy_scanner": "domain-ai-bot-policy-scanner",
    "go_domain_open_source_presence": "domain-open-source-presence",
    "go_domain_documentation_platform_detector": "domain-documentation-platform-detector",
    "go_domain_compliance_claim_scanner": "domain-compliance-claim-scanner",
    "go_domain_trust_composite_grader": "domain-trust-composite-grader"
  },
  "default_strategy": "kebab_strip_go_prefix"
}
