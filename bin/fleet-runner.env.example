# fleet-runner.env.example — canonical env vars for the operator
# workstation's `fleet-runner` shim. Source ONE of:
#
#   - ~/.fleet-runner.env  (auto-sourced by bash/zsh if you `source` it
#     from your shell rc; the shim itself doesn't auto-load this file)
#   - exported in your shell rc directly (~/.zshrc, ~/.bashrc)
#   - inline on a single invocation:
#         APIKEY_SERVICE_URL=… fleet-runner key list
#
# The shim forwards a fixed whitelist of env vars from the workstation
# through SSH + `pct exec` into LXC 108. The whitelist lives at the top
# of bin/fleet-runner-shim — keep this file's vars and the shim's
# whitelist in lockstep.
#
# WHY this file exists: ADR-0027 (fleet-auth canonical flow) and the
# `fleet-runner key …` family require APIKEY_SERVICE_URL set to the
# DOCKERHOST host_port — not LXC 108's localhost. Without it, every
# admin op errors with "keystore unavailable: dial localhost:18021".
# Documenting it here so new workstations / fresh sessions don't have
# to re-derive.

# ── Keystore / vault admin (ADR-0027) ────────────────────────────────

# Dockerhost host_port mapping for go-apikey-service (container :8080
# → dockerhost :18021). The shim forwards this so LXC 108's
# fleet-runner can reach the keystore without going through nginx.
export APIKEY_SERVICE_URL=http://10.10.10.20:18021

# The admin token for go-apikey-service. Value lives in
# private fleet-state/OPS.md under "keystore admin token". REQUIRED
# for any `fleet-runner key …` invocation (issue/provision/revoke/list/rotate).
# Empty string here so you get a clear error if it's unset; replace
# with the real value from OPS.md.
export APIKEY_SERVICE_ADMIN_TOKEN=

# Same shape, different service. The admin token for go-fleet-secrets
# (vault). Value also in fleet-state/OPS.md. REQUIRED for
# `fleet-runner deploy --bootstrap` on any service that declares
# `secrets:` in its service.yaml (ADR-0023, ADR-0025).
export FLEET_SECRETS_ADMIN_TOKEN=

# ── SSH topology (rarely overridden) ─────────────────────────────────

# Bastion + dockerhost SSH targets. Defaults baked into the shim
# match the current production setup; uncomment only if you operate
# from a different SSH topology (e.g. a CI box with its own bastion).
# export FLEET_BASTION=root@0docker.com
# export FLEET_DOCKERHOST=ubuntu_vm@10.10.10.20

# ── External APIs (only for bootstrap deploys) ───────────────────────

# Hetzner Cloud token. Required by `fleet-runner deploy --bootstrap`
# to provision the A record before the first container roll. The shim
# forwards both HCLOUD_TOKEN (canonical) and HETZNER_TOKEN
# (back-compat alias) — set EITHER.
# export HCLOUD_TOKEN=

# GitHub PAT for `gh` operations done inside LXC 108 (e.g. PR
# creation via `fleet-runner push --pr`). Optional — only matters for
# the --pr flow; direct-push flows don't need it.
# export GITHUB_TOKEN=

# ── Smoke test ───────────────────────────────────────────────────────
#
# Once sourced, verify:
#
#   fleet-runner key list --json | head -c 200
#       — should return JSON (not "keystore unavailable").
#   fleet-runner audit fleet-auth-scope
#       — should run end-to-end; expect findings or "0 findings".
#
# If you get "keystore unavailable: dial localhost:18021", the shim
# isn't forwarding APIKEY_SERVICE_URL. Update the shim's whitelist
# (top of bin/fleet-runner-shim) or upgrade to the current version
# in services-registry main.
